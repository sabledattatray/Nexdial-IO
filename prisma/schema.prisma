generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =======================
// NEXTAUTH REQUIRED MODELS
// =======================

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =======================
// APPLICATION MODELS
// =======================

model Workspace {
  id           String  @id @default(cuid())
  name         String
  tagline      String?
  primaryColor String? @default("#0057D9")
  logoUrl      String?

  // Settings
  whatsappNumber String?
  supportEmail   String?

  // Onboarding Metadata
  onboardingData Json? @map("onboarding_data")

  // Billing & Status
  plan        String    @default("TRIAL") // TRIAL, SMALL, MEDIUM, LARGE
  status      String    @default("ACTIVE") // ACTIVE, SUSPENDED
  razorpayId  String?
  trialEndsAt DateTime?
  
  // Metrics
  healthScore Int       @default(100) @map("health_score")
  lastLoginAt DateTime? @map("last_login_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users User[]
  leads Lead[]
  integrations Integration[]
  routingRules RoutingRule[]
  auditLogs    AuditLog[]

  @@map("workspaces")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  role          Role      @default(VIEWER)
  onboarded     Boolean   @default(false)
  industry      String?
  phone         String?
  jobTitle      String?   @map("job_title")

  workspaceId String?    @map("workspace_id")
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // NextAuth
  accounts Account[]
  sessions Session[]

  // Relations
  calls         Call[]
  activities    Activity[]
  assignedLeads Lead[]     @relation("AssignedLeads")

  @@map("users")
}

enum Role {
  ADMIN
  SALES
  VIEWER
}

model Lead {
  id     String     @id @default(uuid()) @db.Uuid
  name   String
  phone  String
  email  String?
  source LeadSource @default(MANUAL)
  status LeadStatus @default(NEW)
  tags   String[]

  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  assignedToId String?   @map("assigned_to_id")
  assignedTo   User?     @relation("AssignedLeads", fields: [assignedToId], references: [id], onDelete: SetNull)
  followUpDate DateTime? @map("follow_up_date")
  notes        String[]
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  calls             Call[]
  activities        Activity[]
  followUps         FollowUp[]
  aiRecommendations AIRecommendation[]

  // Performance Indexes
  @@index([status])
  @@index([workspaceId])
  @@index([assignedToId])
  @@index([followUpDate])
  @@index([createdAt])
  @@index([phone])
  @@index([email])
  @@map("leads")
}

enum LeadSource {
  WHATSAPP
  CALL
  FORM
  MANUAL
  CSV
  WEBSITE
}

enum LeadStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  INTERESTED
  CONVERTED
  LOST
}

model Call {
  id          String      @id @default(cuid())
  leadId      String      @map("lead_id") @db.Uuid
  type        CallType
  outcome     CallOutcome
  notes       String?
  timestamp   DateTime    @default(now())
  createdById String?     @map("created_by_id")

  // Relations
  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([timestamp])
  @@map("calls")
}

enum CallType {
  INCOMING
  OUTGOING
  MISSED
}

enum CallOutcome {
  NO_ANSWER
  INTERESTED
  NOT_INTERESTED
  CALLBACK
  CONVERTED
  LEFT_VOICEMAIL
}

model Activity {
  id          String   @id @default(cuid())
  leadId      String   @map("lead_id") @db.Uuid
  type        String
  description String
  createdById String?  @map("created_by_id")
  timestamp   DateTime @default(now())

  // Relations
  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([timestamp])
  @@map("activities")
}

model FollowUp {
  id          String         @id @default(cuid())
  leadId      String         @map("lead_id") @db.Uuid
  scheduledAt DateTime       @map("scheduled_at")
  status      FollowUpStatus @default(PENDING)
  notes       String?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // Relations
  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([scheduledAt])
  @@index([status])
  @@index([leadId])
  @@map("follow_ups")
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model AIRecommendation {
  id             String   @id @default(cuid())
  leadId         String   @map("lead_id") @db.Uuid
  recommendation String
  category       String
  status         String   @default("PENDING") // PENDING, FOLLOWED, SKIPPED, SNOOZED
  reasoning      String[]
  weightModifier Float    @default(0.0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("ai_recommendations")
}

model Integration {
  id          String    @id @default(cuid())
  workspaceId String    @map("workspace_id")
  provider    String    // "facebook", "instagram", "tiktok", "custom"
  status      String    @default("ACTIVE") // ACTIVE, ERROR, PAUSED
  secretKey   String?   @unique @map("secret_key")
  credentials Json?     // To store { accessToken, pageId, etc }
  leadsCount  Int       @default(0) @map("leads_count")
  lastSyncAt  DateTime? @map("last_sync_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  webhookLogs WebhookLog[]

  @@index([workspaceId])
  @@index([provider])
  @@map("integrations")
}

model WebhookLog {
  id            String   @id @default(cuid())
  integrationId String   @map("integration_id")
  payload       Json
  status        String   // "SUCCESS", "ERROR"
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
  @@map("webhook_logs")
}

model RoutingRule {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  name        String
  priority    Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  conditions  Json     // e.g., [{ "field": "source", "operator": "equals", "value": "facebook" }]
  actions     Json     // e.g., [{ "type": "assignTo", "value": "user_id" }, { "type": "addTag", "value": "Hot" }]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([priority])
  @@map("routing_rules")
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // e.g., "PLAN_UPGRADE", "WORKSPACE_SUSPENDED", "IMPERSONATION_STARTED"
  adminId     String?  @map("admin_id") // ID of the super admin who performed the action
  workspaceId String?  @map("workspace_id")
  details     Json?    // Optional payload describing the action
  createdAt   DateTime @default(now()) @map("created_at")

  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([adminId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  message     String   @db.Text
  type        String   @default("INFO") // INFO, WARNING, SUCCESS, ERROR
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isPublished])
  @@map("announcements")
}
